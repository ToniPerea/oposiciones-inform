# EmailJS credentials
# Copy this file to .env and fill in your values from emailjs.com
# Then run: pnpm set-env

EMAILJS_PUBLIC_KEY=your_public_key_here
EMAILJS_SERVICE_ID=your_service_id_here
EMAILJS_CONFIRMATION_TEMPLATE_ID=your_confirmation_template_id_here
EMAILJS_NOTIFICATION_TEMPLATE_ID=your_notification_template_id_here
